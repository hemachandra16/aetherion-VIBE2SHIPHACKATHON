# Aetherion Backend — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK (service account JSON path OR inline JSON)
# Option A: path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option B: inline JSON string (useful for Cloud Run env vars)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"concrete-arcadia-r7krv",...}

FIREBASE_PROJECT_ID=concrete-arcadia-r7krv

# Server settings
PORT=8000
HOST=0.0.0.0
